# Skopiuj ten plik jako .env. Nigdy nie commituj prawdziwych sekretów.
GEMINI_API_KEY=
# Fine-grained token tylko do wybranych repo materiałów: Repository permissions → Contents: Read and write.
GITHUB_CONTENT_TOKEN=
# Opcjonalna lista wielu repo; gdy jest ustawiona, zastępuje trzy ustawienia pojedynczego repo poniżej.
GITHUB_CONTENT_REPOSITORIES=
GITHUB_CONTENT_REPOSITORY=Kuczis-Media/chemdisk-content
GITHUB_CONTENT_REF=main
GITHUB_CONTENT_ROOT=
NETLIFY_API_TOKEN=
SITE_ID=
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_
